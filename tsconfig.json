{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "react-jsx", // Importante para o React 18+
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "skipLibCheck": true, // Pula a verificação de tipos de bibliotecas externas (evita erros chatos)
    "strict": false, // Mude para false temporariamente para conseguir fazer o deploy
    "noImplicitAny": false, // Resolve os erros de "Parameter implicitly has an any type"
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}